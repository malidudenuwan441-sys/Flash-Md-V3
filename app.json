{
  "name": "Flash-MD3",
  "description": "WhatsApp Multi-Device bot powered by Baileys",
  "repository": "https://github.com/franceking1/Flash-Md-V3",
  "keywords": ["whatsapp", "baileys", "bot", "flash-md"],
  "env": {
    "MODE": {
      "description": "Bot mode (private or public)",
      "value": "private",
      "required": false
    },
    "PREFIXES": {
      "description": "Command prefixes (comma separated)",
      "value": ".",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "+94719531525",
      "value": "",
      "required": false
    },
    "OWNER_NAME": {
      "description": "Malidu",
      "value": "",
      "required": false
    },
    "SESSION": {
      "description": "",
      "required": true
    },
    "TZ": {
      "description": "Timezone",
      "value": "Africa/Nairobi",
      "required": false
    },
    "ANTICALL": {
      "description": "Auto reject calls (on/off)",
      "value": "off",
      "required": false
    },
    "ANTIDELETE": {
      "description": "Detect deleted messages (on/off)",
      "value": "on",
      "required": false
    },
    "ANTIEDIT": {
      "description": "Detect edited messages (on/off)",
      "value": "on",
      "required": false
    },
    "AUTO_READ": {
      "description": "Auto read incoming messages (on/off)",
      "value": "off",
      "required": false
    },
    "AUTO_VIEW": {
      "description": "Auto view status updates (on/off)",
      "value": "on",
      "required": false
    },
    "AUTO_LIKE": {
      "description": "Auto react to status updates (on/off)",
      "value": "off",
      "required": false
    },
    "DM_PRESENCE": {
      "description": "Presence type for private chats (typing/recording/online)",
      "value": "typing",
      "required": false
    },
    "GRP_PRESENCE": {
      "description": "Presence type for groups (typing/recording/online)",
      "value": "recording",
      "required": false
    },
    "USER_LID": {
      "description": "19233534685389",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "stack": "heroku-24"
}
